rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Admins Collection ─────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Users Collection ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();

      match /results/{resultId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      match /schedule/{scheduleId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
    }

    // ── Courses Collection ────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /questions/{questionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── Universities Collection ───────────────────────────────────────
    match /universities/{universityId} {
      allow read: if true;
      allow write: if isAdmin();

      match /faculties/{facultyId} {
        allow read: if true;
        allow write: if isAdmin();

        match /departments/{departmentId} {
          allow read: if true;
          allow write: if isAdmin();

          match /levels/{levelId} {
            allow read: if true;
            allow write: if isAdmin();

            match /courses/{courseId} {
              allow read: if true;
              allow write: if isAdmin();
            }
          }
        }
      }
    }

    // ── Subscription Events ───────────────────────────────────────────
    match /subscription_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Registrations subcollection
      match /registrations/{uid} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
        allow create: if isSignedIn();
        allow delete: if isAdmin();
      }

      // Keys subcollection — one-time-use registration keys
      match /keys/{keyId} {
        // Allow authenticated users to read a specific key document by ID.
        // The path size check (depth == 6) prevents listing all keys at the
        // collection level, which would expose all keys to enumeration.
        allow read: if isSignedIn() && request.path.size() == 6;

        // Only admins can create/write keys
        allow write: if isAdmin();

        // Validate key document structure on write
        allow create: if isAdmin()
          && request.resource.data.keys().hasAll(['used', 'createdAt'])
          && request.resource.data.used == false
          && request.resource.data.keys().hasOnly(['used', 'usedBy', 'usedAt', 'createdAt']);

        allow update: if isAdmin()
          || (isSignedIn()
              && request.resource.data.used == true
              && request.resource.data.usedBy == request.auth.uid
              && request.writeFields.size() == 1
              && request.writeFields.hasOnly(['used']));
      }
    }

    // ── Leaderboard ───────────────────────────────────────────────────
    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── Inbox / Notifications ─────────────────────────────────────────
    match /inbox/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Maintenance Mode ──────────────────────────────────────────────
    match /maintenance/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Default Deny ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
