{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/quiz",
        "destination": "/quiz.html"
      },
      {
        "source": "/quiz?*",
        "destination": "/quiz.html"
      }
    ],
    "cleanUrls": true
  },
  "functions": {
    "source": "functions"
  }
}
