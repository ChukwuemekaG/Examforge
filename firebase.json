{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "venv/**",
      ".git/**",
      "agent.py",
      "**/*.py",
      "**/*.pyc",
      "__pycache__/**"
    ],
    "rewrites": [
      {
        "source": "/quiz",
        "destination": "/quiz.html"
      },
      {
        "source": "/quiz?*",
        "destination": "/quiz.html"
      },
      {
        "source": "/v2/pipeline",
        "function": "tursoProxy"
      }
    ],
    "cleanUrls": true
  }
}
